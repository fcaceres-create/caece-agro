# Entornos virtuales
.venv/
venv/
env/

# Bytecode y caches de Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter
.ipynb_checkpoints/

# Datos regenerables (descargados desde APIs)
data/cache/
data/raw/

# Modelos serializados (regenerables)
