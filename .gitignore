# definimos configuración común para el equipo.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Sistema operativo
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# Tests y cobertura
.pytest_cache/
.coverage
htmlcov/

# Build / distribución
build/
dist/
*.egg-info/

data/processed/
data/modelos/
